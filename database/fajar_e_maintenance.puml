@startuml fajar_e_maintenance

entity function_locations
{
    * id VARCHAR(150) <<PK>>
    --
      tag_name VARCHAR(100)
      created_at TIMESTAMP NULL
      updated_at TIMESTAMP NULL
}

entity emos
{
    * id VARCHAR(9) <<PK>>
    * funcloc VARCHAR (150) <<FK>>
    --
      material_number VARCHAR(8)
    * equipment_description VARCHAR(150)
    * status ENUM(["Installed", "Repaired", "Available"])
    * sort_field VARCHAR(100)
    * unique_id VARCHAR(6) UNIQUE
    * qr_code_link VARCHAR(100) 
      created_at TIMESTAMP NULL
      updated_at TIMESTAMP NULL
}

entity emo_details {
    * id BIGINT UNSIGNED AUTO_INCREMENT
    * emo_detail VARCHAR(9) <<FK>>
    --
    manufacture VARCHAR(150)
    serial_number VARCHAR(150)
    type VARCHAR(150)
    power_rate VARCHAR(5)
    power_unit ENUM(["kW", "HP"])

    voltage VARCHAR(25)
    current_nominal VARCHAR(25)
    frequency VARCHAR(3)
    pole VARCHAR(25)
    rpm VARCHAR(25)

    bearing_de VARCHAR("50")
    bearing_nde VARCHAR("50")
    frame_type VARCHAR("50")
    shaft_diameter SMALLINT UNSIGNED
    phase_supply VARCHAR(3)

    cos_phi CHAR(4)
    efficiency VARCHAR(4)
    ip_rating CHAR(2)
    insulation_class CHAR(1)
    duty CHAR(2)

    connection_type VARCHAR(50)
    nipple_grease ENUM(["Available", "Not Available"])
    greasing_type VARCHAR(50)
    greasing_qty_de SMALLINT UNSIGNED
    greasing_qty_nde SMALLINT UNSIGNED

    length SMALLINT UNSIGNED
    width SMALLINT UNSIGNED
    height SMALLINT UNSIGNED
    weight SMALLINT UNSIGNED
    cooling_fan ENUM(["Internal", "External", "Not Available"])

    mounting ENUM("Horizontal", "Vertical", "V/H", "MGM")
}

entity data_records {
    * id BIGINT UNSIGNED AUTO_INCREMENT
    * funcloc VARCHAR(150) <<FK>>
    * emo VARCHAR(9) <<FK>>
    --
    * motor_status ENUM(["Running", "Not Running"])
    * clean_status ENUM(["Clean", "Dirty"])
    * nipple_grease ENUM(["Available", "Not Available"])
      number_of_greasing CHAR(3)
    * temperature_a SMALLINT UNSIGNED
    * temperature_b SMALLINT UNSIGNED
    * temperature_c SMALLINT UNSIGNED
    * temperature_d SMALLINT UNSIGNED
      vibration_value_de DECIMAL(4,2)
    * vibration_de ENUM(["Normal", "Abnormal"])
      vibration_value_nde DECIMAL(4,2)
    * vibration_nde ENUM(["Normal", "Abnormal"])
    * created_at TIMESTAMP
    * checked_by VARCHAR(150)
}

entity users {
    * nik VARCHAR(8)
    --
    * password VARCHAR(50)
    * fullname VARCHAR(150)
    * department ENUM("EI1-EI7");
    * phone_number VARCHAR(15)
}
 
function_locations ||--o{ emos : Have
function_locations ||--o{ data_records : Have
emos ||--o{ data_records : Have
emos ||--|| emo_details : Contain
data_records ||--|| users : Include


@enduml